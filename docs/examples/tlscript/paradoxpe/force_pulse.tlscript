# Spawn a body, kick it, and probe contacts through the handle-based ABI.
@export
def force_pulse():
    let body = spawn_body(2, 0.0, 1.0, 1.0)
    let shape = spawn_collider(body, 0, 0.5, 0.0)
    apply_force(body, 12.0, 24.0)
    set_velocity(body, 2.0, 6.0)
    let contacts = query_contacts(body)
    let overlap_count: int = contact_count(contacts)
